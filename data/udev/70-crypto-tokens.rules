# BigCertificados — udev rules for Brazilian digital certificate tokens
# Install to /etc/udev/rules.d/70-crypto-tokens.rules
# Then run: sudo udevadm control --reload-rules && sudo udevadm trigger

# ── SafeNet / Thales ──
# eToken 5110, 5110+ FIPS
SUBSYSTEM=="usb", ATTR{idVendor}=="0529", ATTR{idProduct}=="0620", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# eToken 5300, 5300-C
SUBSYSTEM=="usb", ATTR{idVendor}=="0529", ATTR{idProduct}=="0621", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# eToken 7300
SUBSYSTEM=="usb", ATTR{idVendor}=="0529", ATTR{idProduct}=="0622", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# eToken PRO 72K
SUBSYSTEM=="usb", ATTR{idVendor}=="0529", ATTR{idProduct}=="0600", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# eToken PRO Java
SUBSYSTEM=="usb", ATTR{idVendor}=="0529", ATTR{idProduct}=="0514", MODE="0660", GROUP="plugdev", TAG+="uaccess"

# ── Gemalto / Thales ──
# IDBridge CT40
SUBSYSTEM=="usb", ATTR{idVendor}=="08e6", ATTR{idProduct}=="3437", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# IDBridge CT710, IDPrime MD 830/840
SUBSYSTEM=="usb", ATTR{idVendor}=="08e6", ATTR{idProduct}=="3438", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# IDBridge K30, IDOne Cosmo V7
SUBSYSTEM=="usb", ATTR{idVendor}=="08e6", ATTR{idProduct}=="34ec", MODE="0660", GROUP="plugdev", TAG+="uaccess"
# IDBridge K50
SUBSYSTEM=="usb", ATTR{idVendor}=="08e6", ATTR{idProduct}=="3479", MODE="0660", GROUP="plugdev", TAG+="uaccess"

